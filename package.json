{
  "name": "rolay-server",
  "version": "0.1.0",
  "private": true,
  "description": "Rolay server skeleton for realtime markdown collaboration and file sync.",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "dev:web": "vite --config public-web/vite.config.ts --host 0.0.0.0",
    "build": "npm run build:server && npm run build:web",
    "build:server": "tsc -p tsconfig.json",
    "build:web": "vite build --config public-web/vite.config.ts",
    "start": "node dist/src/index.js",
    "typecheck": "npm run typecheck:server && npm run typecheck:web",
    "typecheck:server": "tsc --noEmit -p tsconfig.json",
    "typecheck:web": "tsc --noEmit -p public-web/tsconfig.json",
    "test": "tsx --test test/app.test.ts"
  },
  "dependencies": {
    "@codemirror/lang-markdown": "^6.3.4",
    "@codemirror/state": "^6.5.2",
    "@codemirror/view": "^6.38.8",
    "@excalidraw/excalidraw": "^0.17.6",
    "@hocuspocus/provider": "^3.4.4",
    "@hocuspocus/server": "^3.4.4",
    "fastify": "^5.0.0",
    "katex": "^0.16.45",
    "minio": "^8.0.7",
    "pg": "^8.20.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "ws": "^8.20.0",
    "yjs": "^13.6.30"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/pg": "^8.20.0",
    "@types/ws": "^8.18.1",
    "tsx": "^4.0.0",
    "typescript": "^5.0.0",
    "vite": "^8.0.10"
  }
}
